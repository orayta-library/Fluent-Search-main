<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MySearchApp.ViewModels"
        xmlns:controls="clr-namespace:MySearchApp.Controls"
        x:Class="MySearchApp.MainWindow"
        Width="1000" Height="600"
        Title="MySearchApp">

  <Window.DataContext>
    <vm:MapViewModel />
  </Window.DataContext>

  <Grid ColumnDefinitions="240,*,320">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Top toolbar: center coords and zoom -->
    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="8" Padding="8">
      <TextBlock VerticalAlignment="Center" Text="Maps Demo" FontWeight="Bold" />
      <TextBox Width="220" Watermark="Center coordinates (lat,lon)" Text="{Binding CenterCoordinates, Mode=TwoWay}" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Zoom +" Command="{Binding ZoomInCommand}" Margin="4,0" />
        <Button Content="Zoom -" Command="{Binding ZoomOutCommand}" Margin="4,0" />
        <Button Content="Open Map" Command="{Binding OpenMapCommand}" Margin="8,0" />
      </StackPanel>
    </StackPanel>

    <!-- Left: Layers / tools -->
    <Border Grid.Row="1" Grid.Column="0" Padding="8" BorderBrush="#22000000" BorderThickness="0,0,1,0">
      <StackPanel>
        <TextBlock Text="Layers" FontWeight="Bold" Margin="0,0,0,8" />
        <ListBox Items="{Binding Layers}" SelectedItem="{Binding SelectedLayer}" DisplayMemberPath="Name" />
        <Button Content="Add Layer" Command="{Binding AddLayerCommand}" Margin="0,8,0,0" />
      </StackPanel>
    </Border>

    <!-- Center: Map Canvas placeholder -->
    <Border Grid.Row="1" Grid.Column="1" Background="#FFEEEEEE">
      <Grid>
        <TextBlock Text="Map canvas (placeholder)" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8" Opacity="0.7" />
        <Rectangle Fill="#FFD0DFF0" Stroke="#FF9AB" StrokeThickness="1" Margin="24" RadiusX="4" RadiusY="4" />
        <TextBlock Text="Zoom: {Binding ZoomLevel}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8" />
      </Grid>
    </Border>

    <!-- Right: Info / preview -->
    <Border Grid.Row="1" Grid.Column="2" Padding="8" BorderBrush="#22000000" BorderThickness="1,0,0,0">
      <StackPanel>
        <TextBlock Text="Map Info" FontWeight="Bold" />
        <TextBlock Text="Selected Layer:" Margin="0,8,0,0" />
        <TextBlock Text="{Binding SelectedLayer.Name}" FontWeight="SemiBold" />
        <TextBlock Text="Center:" Margin="0,12,0,0" />
        <TextBlock Text="{Binding CenterCoordinates}" />
        <Button Content="Reset View" Command="{Binding ResetViewCommand}" Margin="0,12,0,0" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
