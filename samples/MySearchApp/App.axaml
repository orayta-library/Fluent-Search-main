<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:themes="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="MySearchApp.App">
  <Application.Styles>
    <themes:FluentTheme Mode="Light" />
    <StyleInclude Source="avares://Avalonia.Themes.Fluent/Accents/BaseLight.xaml" />
  </Application.Styles>
</Application>
